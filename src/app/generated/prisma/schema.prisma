generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS (Type safety for your logic) ---

enum Role {
  USER
  ADMIN
}

enum PlanType {
  MINGGUAN
  BULANAN
  TAHUNAN
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum BoxStatus {
  PENDING_SELECTION
  SELECTION_LOCKED
  COMPLETED
  SKIPPED
}

enum DeliveryStatus {
  PREPARING
  SHIPPED
  DELIVERED
}

enum DayOfWeek {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
  MINGGU
}

// --- MODELS ---

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  // Relations
  addresses     Address[]
  subscriptions Subscription[]
  transactions  Transaction[]
  weeklyBoxes   WeeklyBox[]
  deliveries    Delivery[]
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String // e.g., "Rumah", "Kantor"
  street     String
  city       String
  province   String
  postalCode String
  notes      String?
  isDefault  Boolean @default(false)

  user       User       @relation(fields: [userId], references: [id])
  deliveries Delivery[]
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  planType    PlanType
  servings    Int
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  pausedUntil DateTime?

  user User @relation(fields: [userId], references: [id])
}

model Transaction {
  id        String            @id @default(cuid())
  userId    String
  amount    Float
  status    TransactionStatus @default(PENDING)
  qrisCode  String
  paidAt    DateTime?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WeeklyBox {
  id                String    @id @default(cuid())
  userId            String
  weekStartDate     DateTime
  weekEndDate       DateTime
  selectionDeadline DateTime
  isAutoSelected    Boolean   @default(false)
  status            BoxStatus @default(PENDING_SELECTION)

  user           User            @relation(fields: [userId], references: [id])
  mealSelections MealSelection[]
  deliveries     Delivery[]
}

model Recipe {
  id          String @id @default(cuid())
  name        String
  description String @db.Text
  servings    Int

  mealSelections MealSelection[]
  weeklyMenus    WeeklyMenu[]
}

model WeeklyMenu {
  id            String   @id @default(cuid())
  recipeId      String
  weekStartDate DateTime

  recipe Recipe @relation(fields: [recipeId], references: [id])
}

model MealSelection {
  id          String    @id @default(cuid())
  weeklyBoxId String
  recipeId    String
  dayOfWeek   DayOfWeek

  weeklyBox WeeklyBox @relation(fields: [weeklyBoxId], references: [id])
  recipe    Recipe    @relation(fields: [recipeId], references: [id])
}

model Delivery {
  id           String         @id @default(cuid())
  userId       String
  weeklyBoxId  String
  addressId    String
  deliveryDate DateTime
  status       DeliveryStatus @default(PREPARING)
  shippedAt    DateTime?
  deliveredAt  DateTime?

  user      User      @relation(fields: [userId], references: [id])
  weeklyBox WeeklyBox @relation(fields: [weeklyBoxId], references: [id])
  address   Address   @relation(fields: [addressId], references: [id])
}
